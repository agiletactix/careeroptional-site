---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "The skills that make employment optional. A podcast by Danny Liu." } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title === 'Career Optional' ? title : `${title} | Career Optional`}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Career Optional Podcast" href="/podcast.xml" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Styles loaded via frontmatter import to avoid Astro scoping -->
</head>
<body class="flex flex-col min-h-screen">
  <nav class="fixed top-0 left-0 right-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-border">
    <div class="section-container py-6">
      <div class="flex items-center justify-between">
        <a href="/" class="font-bold text-lg tracking-tight hover:text-ink no-underline">
          <span class="text-gray-900">Career </span><span class="text-accent">Optional</span>
        </a>
        <div class="flex items-center gap-6 sm:gap-8">
          <a href="/podcast/" class="text-ink-light hover:text-ink text-sm font-medium no-underline">Episodes</a>
          <a href="/offers/" class="text-ink-light hover:text-ink text-sm font-medium no-underline">Offers</a>

        </div>
      </div>
    </div>
  </nav>

  <!-- Spacer for fixed nav -->
  <div class="h-[76px]"></div>

  <main class="flex-grow">
    <slot />
  </main>

  <footer class="border-t border-border py-12">
    <div class="section-container text-center">
      <p class="text-ink-muted text-sm">
        &copy; {new Date().getFullYear()} AgileTactix LLC &middot; A podcast by <a href="http://dannyjliu.com" class="text-accent hover:text-accent-hover no-underline">Danny J. Liu</a>
      </p>
    </div>
  </footer>
</body>
</html>
