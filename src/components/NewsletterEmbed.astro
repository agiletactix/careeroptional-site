---
---

<section id="subscribe" class="section-spacing bg-white border-y border-border">
  <div class="section-container">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-accent font-semibold text-sm tracking-wide uppercase mb-3">Newsletter</p>
      <h2 class="text-3xl font-bold text-ink mb-4">Get the weekly drop.</h2>
      <p class="text-ink-light text-lg mb-8">
        Five episodes a week. Career strategy meets AI automation.
        Delivered to your inbox every Monday.
      </p>

      <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input
          type="email"
          name="email_address"
          placeholder="Your email"
          required
          class="flex-1 px-4 py-3 rounded-full border border-gray-300 text-base focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-full bg-gray-900 text-white font-semibold text-sm hover:bg-gray-700 hover:-translate-y-0.5 hover:shadow-md transition-all"
        >
          Subscribe
        </button>
      </form>
      <p id="newsletter-success" class="text-green-600 font-medium mt-4 hidden">You're in! Check your inbox.</p>
      <p id="newsletter-error" class="text-red-600 font-medium mt-4 hidden">Something went wrong. Try again.</p>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('newsletter-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = this;
    var btn = form.querySelector('button');
    var email = form.querySelector('input[name="email_address"]').value;
    btn.textContent = 'Subscribing...';
    btn.disabled = true;

    if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
      form.classList.add('hidden');
      document.getElementById('newsletter-success').classList.remove('hidden');
      return;
    }
    fetch('https://app.kit.com/forms/9222590/subscriptions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'email_address=' + encodeURIComponent(email),
      redirect: 'manual'
    }).then(function(res) {
      if (res.ok || res.status === 302 || res.type === 'opaqueredirect') {
        form.classList.add('hidden');
        document.getElementById('newsletter-success').classList.remove('hidden');
      } else {
        document.getElementById('newsletter-error').classList.remove('hidden');
        btn.textContent = 'Subscribe';
        btn.disabled = false;
      }
    }).catch(function() {
      document.getElementById('newsletter-error').classList.remove('hidden');
      btn.textContent = 'Subscribe';
      btn.disabled = false;
    });
  });
</script>
