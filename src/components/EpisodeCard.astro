---
import { Image } from 'astro:assets';
import podcastArt from '../assets/images/podcast-art.png';

interface Props {
  title: string;
  slug: string;
  episodeNumber?: number;
  description: string;
  pubDate: Date;
  duration: string;
}

const { title, slug, episodeNumber, description, pubDate, duration } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<a href={`/podcast/${slug}/`} class="block group no-underline">
  <article class="p-6 rounded-lg border border-border hover:border-gray-300 hover:shadow-sm hover:-translate-y-0.5 bg-white/50 transition-all">
    <div class="flex items-start gap-4">
      <Image
        src={podcastArt}
        alt="Career Optional"
        class="w-12 h-12 rounded-lg flex-shrink-0 object-cover"
        width={96}
        height={96}
      />

      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-3 mb-1">
          {episodeNumber !== undefined && (
            <span class="text-xs font-bold bg-accent text-white px-2 py-0.5 rounded-md">EP {episodeNumber}</span>
          )}
          <span class="text-ink-muted text-xs">{formattedDate}</span>
          <span class="text-ink-muted text-xs">{duration}</span>
        </div>

        <h3 class="text-lg font-semibold text-ink group-hover:text-accent-hover transition-colors leading-snug">
          {title}
        </h3>

        <p class="text-ink-light text-sm mt-2 line-clamp-2">
          {description}
        </p>
      </div>
    </div>
  </article>
</a>
