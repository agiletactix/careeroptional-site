---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Offers" description="Tools and resources to build career optionality. From free playbooks to premium automation kits.">
  <section class="section-spacing">
    <div class="section-container">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold text-ink mb-4">Offers</h1>
        <p class="text-ink-light text-lg mb-12">
          Tools to help you build career optionality — from free downloads to hands-on kits.
        </p>

        <!-- AI Prompt Playbook -->
        <div class="border border-border rounded-lg p-8 mb-6 bg-white/50">
          <span class="text-accent text-xs font-semibold uppercase tracking-wide">Free</span>
          <h2 class="text-2xl font-bold text-ink mt-2 mb-3">The AI Prompt Playbook for Agile Pros</h2>
          <p class="text-ink-light mb-6">
            A curated collection of production-ready AI prompts for Scrum Masters, Product Owners, and delivery leads.
            Stop experimenting and start automating.
          </p>
          <a href="https://agiletactix.ai/blueprint" class="inline-block text-sm font-semibold px-6 py-3 bg-accent text-white rounded-lg hover:bg-accent-hover transition-colors no-underline">
            Get the Free Playbook
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
