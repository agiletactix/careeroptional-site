---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Offers" description="Tools and resources to build career optionality. From free playbooks to premium automation kits.">
  <section class="pt-28 pb-16">
    <div class="section-container max-w-3xl">
      <h1 class="text-4xl font-bold text-ink mb-4">Offers</h1>
      <p class="text-ink-light text-lg mb-12">
        Tools to help you build career optionality — from free downloads to hands-on kits.
      </p>

      <!-- AI Prompt Playbook -->
      <div class="border border-border rounded-lg p-8 mb-6 bg-white/50">
        <span class="text-agile-blue text-xs font-semibold uppercase tracking-wide">Free</span>
        <h2 class="text-2xl font-bold text-ink mt-2 mb-3">The AI Prompt Playbook for Agile Pros</h2>
        <p class="text-ink-light mb-6">
          A curated collection of production-ready AI prompts for Scrum Masters, Product Owners, and delivery leads.
          Stop experimenting and start automating.
        </p>
        <span class="inline-block text-ink-muted text-sm font-medium px-4 py-2 border border-border rounded-lg">
          Coming soon
        </span>
      </div>

      <!-- Sprint Automation Kit -->
      <div class="border border-border rounded-lg p-8 mb-6 bg-white/50">
        <span class="text-sunset-amber text-xs font-semibold uppercase tracking-wide">$27</span>
        <h2 class="text-2xl font-bold text-ink mt-2 mb-3">The 5-Step Sprint Automation Kit</h2>
        <p class="text-ink-light mb-6">
          Templates, scripts, and walkthroughs to automate the five most time-consuming sprint ceremonies.
          Built for practitioners, not theorists.
        </p>
        <span class="inline-block text-ink-muted text-sm font-medium px-4 py-2 border border-border rounded-lg">
          Coming soon
        </span>
      </div>

      <!-- Automation Lab -->
      <div class="border border-border rounded-lg p-8 bg-white/50">
        <span class="text-sunset-amber text-xs font-semibold uppercase tracking-wide">$197</span>
        <h2 class="text-2xl font-bold text-ink mt-2 mb-3">The Automation Lab</h2>
        <p class="text-ink-light mb-6">
          A guided, hands-on lab where you build real automation workflows for Jira, Confluence, and your delivery stack.
          Cohort-based with live support.
        </p>
        <span class="inline-block text-ink-muted text-sm font-medium px-4 py-2 border border-border rounded-lg">
          Coming soon
        </span>
      </div>
    </div>
  </section>
</BaseLayout>
