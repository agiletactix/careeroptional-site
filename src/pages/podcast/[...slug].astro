---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import { getEpisodes, getEpisodeBySlug } from '../../lib/episodes';

export async function getStaticPaths() {
  const episodes = await getEpisodes();
  return episodes.map((episode) => ({
    params: { slug: episode.slug },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const formattedDate = episode.pubDate.toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout title={episode.title} description={episode.description}>
  <article class="section-spacing">
    <div class="section-container">
      <div class="max-w-3xl">
        <!-- Meta -->
        <div class="flex items-center gap-3 mb-4">
          {episode.episodeNumber !== undefined && (
            <span class="text-xs font-bold bg-accent text-white px-2 py-0.5 rounded-md">
              EP {episode.episodeNumber}
            </span>
          )}
          <span class="text-ink-muted text-sm">{formattedDate}</span>
          <span class="text-ink-muted text-sm">{episode.duration}</span>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-ink leading-tight mb-6">
          {episode.title}
        </h1>

        <p class="text-ink-light text-lg mb-8">
          {episode.description}
        </p>

        <!-- Player -->
        <div class="mb-10">
          <AudioPlayer
            title={episode.title}
            episodeNumber={episode.episodeNumber}
            duration={episode.duration}
            audioUrl={episode.audioUrl}
          />
        </div>

        <!-- Show Notes -->
        {episode.contentHtml && (
          <div class="prose-content border-t border-border pt-8">
            <h2 class="text-lg font-semibold text-ink mb-4">Show Notes</h2>
            <Fragment set:html={episode.contentHtml} />
          </div>
        )}

        <!-- Back link -->
        <div class="mt-12 pt-8 border-t border-border">
          <a href="/podcast/" class="text-accent text-sm font-medium hover:text-accent-hover no-underline">
            &larr; All episodes
          </a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
