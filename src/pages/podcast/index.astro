---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';
import { getCollection } from 'astro:content';

const allEpisodes = await getCollection('podcast');
const sortedEpisodes = allEpisodes.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout title="Episodes" description="All episodes of the Career Optional podcast. Daily insights on agile thinking, AI automation, and career optionality.">
  <section class="section-spacing">
    <div class="section-container">
      <h1 class="text-4xl font-bold text-ink mb-2">All Episodes</h1>
      <p class="text-ink-light text-lg mb-12">
        New episodes Monday through Friday. <span class="text-accent font-medium">Fridays are Human Takes</span> — Danny's real voice, unscripted.
      </p>

      <div class="space-y-4">
        {sortedEpisodes.map((episode) => (
          <EpisodeCard
            title={episode.data.title}
            slug={episode.id}
            episodeNumber={episode.data.episodeNumber}
            description={episode.data.description}
            pubDate={episode.data.pubDate}
            duration={episode.data.duration}
            isFriday={episode.data.isFriday}
          />
        ))}
      </div>

      {sortedEpisodes.length === 0 && (
        <div class="text-center py-20">
          <p class="text-ink-muted text-lg">Episodes dropping soon. Stay tuned.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
