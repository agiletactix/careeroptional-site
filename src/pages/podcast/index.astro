---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';
import { getEpisodes } from '../../lib/episodes';

const sortedEpisodes = await getEpisodes();
---

<BaseLayout title="Episodes" description="All episodes of the Career Optional podcast. Daily insights on agile thinking, AI automation, and career optionality.">
  <section class="section-spacing">
    <div class="section-container">
      <h1 class="text-4xl font-bold text-ink mb-2">All Episodes</h1>
      <p class="text-ink-light text-lg mb-12">
        New episodes every week. Real talk on agile, AI, and career optionality.
      </p>

      <div class="space-y-4">
        {sortedEpisodes.map((episode) => (
          <EpisodeCard
            title={episode.title}
            slug={episode.slug}
            episodeNumber={episode.episodeNumber}
            description={episode.description}
            pubDate={episode.pubDate}
            duration={episode.duration}
          />
        ))}
      </div>

      {sortedEpisodes.length === 0 && (
        <div class="text-center py-20">
          <p class="text-ink-muted text-lg">Episodes dropping soon. Stay tuned.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
