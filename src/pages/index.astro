---
import BaseLayout from '../layouts/BaseLayout.astro';
import PodcastHero from '../components/PodcastHero.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import NewsletterEmbed from '../components/NewsletterEmbed.astro';
import { getEpisodes } from '../lib/episodes';

const sortedEpisodes = await getEpisodes();
const latestEpisode = sortedEpisodes[0];
---

<BaseLayout title="Career Optional" description="The skills that make employment optional. A podcast by Danny Liu about agile thinking, AI automation, and career optionality.">
  <!-- Hero -->
  <PodcastHero />

  <!-- Daily Drop — Latest Episode -->
  {latestEpisode && (
    <section class="section-spacing border-t border-border">
      <div class="section-container">
        <p class="text-accent font-semibold text-sm tracking-wide uppercase mb-4">Latest Episode</p>
        <AudioPlayer
          title={latestEpisode.title}
          episodeNumber={latestEpisode.episodeNumber}
          duration={latestEpisode.duration}
          audioUrl={latestEpisode.audioUrl}
        />
      </div>
    </section>
  )}

  <!-- Episode List -->
  <section class="section-spacing border-t border-border">
    <div class="section-container">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-ink">Episodes</h2>
        <a href="/podcast/" class="text-accent text-sm font-medium hover:text-accent-hover no-underline">
          View all &rarr;
        </a>
      </div>

      <div class="space-y-4">
        {sortedEpisodes.slice(0, 5).map((episode) => (
          <EpisodeCard
            title={episode.title}
            slug={episode.slug}
            episodeNumber={episode.episodeNumber}
            description={episode.description}
            pubDate={episode.pubDate}
            duration={episode.duration}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterEmbed />

  <!-- Subscribe Platforms -->
  <section class="section-spacing">
    <div class="section-container text-center">
      <h2 class="text-2xl font-bold text-ink mb-4">Listen everywhere.</h2>
      <p class="text-ink-light mb-8">Available on all major podcast platforms.</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="https://open.spotify.com/show/5S0wWKuLzuhvqgF6cS8eLr" target="_blank" rel="noopener" class="inline-flex items-center px-5 py-2.5 bg-white rounded-full border border-gray-200 text-sm font-semibold text-gray-700 shadow-sm hover:shadow-md hover:border-gray-400 transition-all no-underline">Spotify</a>
        <a href="https://podcasts.apple.com/us/podcast/career-optional/id1886208605" target="_blank" rel="noopener" class="inline-flex items-center px-5 py-2.5 bg-white rounded-full border border-gray-200 text-sm font-semibold text-gray-700 shadow-sm hover:shadow-md hover:border-gray-400 transition-all no-underline">Apple Podcasts</a>
        <a href="https://www.youtube.com/@agiletactix?sub_confirmation=1" target="_blank" rel="noopener" class="inline-flex items-center px-5 py-2.5 bg-white rounded-full border border-gray-200 text-sm font-semibold text-gray-700 shadow-sm hover:shadow-md hover:border-gray-400 transition-all no-underline">YouTube</a>
      </div>
    </div>
  </section>
</BaseLayout>
